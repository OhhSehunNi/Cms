@model List<Cms.Application.DTOs.ArticleDto>

<h1>文章管理</h1>

<form method="get" action="/admin/articles">
    <div class="form-group">
        <label>关键词</label>
        <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control" />
    </div>
    <div class="form-group">
        <label>栏目</label>
        <select name="channelId" class="form-control">
            <option value="">全部栏目</option>
            <!-- 动态加载栏目列表 -->
        </select>
    </div>
    <button type="submit" class="btn btn-primary">搜索</button>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>标题</th>
            <th>栏目</th>
            <th>状态</th>
            <th>发布时间</th>
            <th>操作</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var article in Model)
        {
            <tr>
                <td>@article.Id</td>
                <td>@article.Title</td>
                <td>@article.ChannelName</td>
                <td>@article.Status</td>
                <td>@article.PublishTime.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a href="/admin/articles/edit/@article.Id" class="btn btn-sm btn-primary">编辑</a>
                    @if (article.Status != "Published")
                    {
                        <form method="post" action="/admin/articles/publish/@article.Id" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-success">发布</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" action="/admin/articles/unpublish/@article.Id" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-warning">下线</button>
                        </form>
                    }
                    <form method="post" action="/admin/articles/delete/@article.Id" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('确定删除？');">删除</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a href="/admin/articles/create" class="btn btn-primary">新建文章</a>