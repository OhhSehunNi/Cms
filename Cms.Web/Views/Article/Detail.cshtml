@model Cms.Web.ViewModels.ArticleViewModel

@{
    ViewData["Title"] = Model.SeoTitle;
    ViewData["SeoTitle"] = Model.SeoTitle;
    ViewData["SeoDescription"] = Model.SeoDescription;
    ViewData["SeoKeywords"] = Model.SeoKeywords;
    ViewData["CanonicalUrl"] = Model.CanonicalUrl;
}

<!-- 面包屑导航 -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">首页</a></li>
        <li class="breadcrumb-item"><a href="/@Model.ChannelSlug">@Model.ChannelName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
    </ol>
</nav>

<div class="row">
    <!-- 主内容区 -->
    <div class="col-lg-8">
        <!-- 文章标题 -->
        <h1>@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Subtitle))
        {
            <h2 class="h4 text-muted">@Model.Subtitle</h2>
        }
        
        <!-- 文章元信息 -->
        <div class="text-muted mb-4">
            <span>作者：@Model.Author</span> | 
            <span>来源：@Model.Source</span> | 
            <span>发布时间：@Model.PublishTime.ToString("yyyy-MM-dd HH:mm")</span> | 
            <span>浏览：@Model.ViewCount</span>
        </div>
        
        <!-- 封面图 -->
        @if (!string.IsNullOrEmpty(Model.CoverImage))
        {
            <div class="mb-4">
                <img src="@Model.CoverImage" class="img-fluid" alt="@Model.Title" />
            </div>
        }
        
        <!-- 文章内容 -->
        <div class="article-content">
            @Html.Raw(Model.Content)
        </div>
        
        <!-- 标签 -->
        @if (Model.Tags != null && Model.Tags.Count > 0)
        {
            <div class="mt-4">
                <span class="text-muted">标签：</span>
                @foreach (var tag in Model.Tags)
                {
                    <a href="/tag/@tag.ToLower()" class="badge text-bg-primary me-2">@tag</a>
                }
            </div>
        }
        
        <!-- 上一篇/下一篇 -->
        <div class="mt-4 d-flex justify-content-between">
            @if (Model.PrevArticle != null)
            {
                <div>
                    <span class="text-muted">上一篇：</span>
                    <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html", Model.PrevArticle.ChannelSlug, Model.PrevArticle.PublishTime.Year, Model.PrevArticle.PublishTime.Month, Model.PrevArticle.PublishTime.Day, Model.PrevArticle.Id))">@Model.PrevArticle.Title</a>
                </div>
            }
            @if (Model.NextArticle != null)
            {
                <div>
                    <span class="text-muted">下一篇：</span>
                    <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html", Model.NextArticle.ChannelSlug, Model.NextArticle.PublishTime.Year, Model.NextArticle.PublishTime.Month, Model.NextArticle.PublishTime.Day, Model.NextArticle.Id))">@Model.NextArticle.Title</a>
                </div>
            }
        </div>
        
        <!-- 相关阅读 -->
        @if (Model.RelatedArticles != null && Model.RelatedArticles.Count > 0)
        {
            <div class="mt-6">
                <h3 class="h5">相关阅读</h3>
                <hr />
                <div class="row">
                    @foreach (var article in Model.RelatedArticles)
                    {
                        <div class="col-md-6 mb-3">
                            <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html", article.ChannelSlug, article.PublishTime.Year, article.PublishTime.Month, article.PublishTime.Day, article.Id))" class="text-dark">@article.Title</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- 侧边栏 -->
    <div class="col-lg-4">
        <!-- 热门文章 -->
        @await Component.InvokeAsync("HotArticles")
        
        <!-- 推荐阅读 -->
        <div class="mt-4">
            @await Component.InvokeAsync("Recommend", new { position = "sidebar", count = 5 })
        </div>
        
        <!-- 标签云 -->
        <div class="mt-4">
            @await Component.InvokeAsync("TagCloud")
        </div>
    </div>
</div>