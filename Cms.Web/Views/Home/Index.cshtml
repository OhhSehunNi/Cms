@model Cms.Web.ViewModels.HomeViewModel

@{
    ViewData["Title"] = Model.SeoTitle;
    ViewData["SeoTitle"] = Model.SeoTitle;
    ViewData["SeoDescription"] = Model.SeoDescription;
    ViewData["SeoKeywords"] = Model.SeoKeywords;
}

@* 顶部：焦点图 + 要闻热榜（门户型布局） *@
<div class="row mb-4">
    <div class="col-lg-8">
        <div class="carousel slide portal-carousel" id="featuredCarousel" data-bs-ride="carousel">
            <div class="carousel-inner">
                @foreach (var article in Model.FeaturedArticles)
                {
                    <div class="carousel-item @(Model.FeaturedArticles.IndexOf(article) == 0 ? "active" : "")">
                        <img src="@article.CoverImage" class="d-block w-100" alt="@article.Title" />
                        <div class="carousel-caption d-none d-md-block">
                            <h3>
                                <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html",
                                            article.ChannelSlug,
                                            article.PublishTime.Year,
                                            article.PublishTime.Month,
                                            article.PublishTime.Day,
                                            article.Id))">
                                    @article.Title
                                </a>
                            </h3>
                            <p>@article.Summary</p>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#featuredCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">上一条</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#featuredCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">下一条</span>
            </button>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sidebar portal-headlines">
            <h3>要闻</h3>
            <ul class="portal-headlines-list">
                @foreach (var article in Model.HotArticles.Take(10))
                {
                    <li>
                        <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html",
                                    article.ChannelSlug,
                                    article.PublishTime.Year,
                                    article.PublishTime.Month,
                                    article.PublishTime.Day,
                                    article.Id))">
                            @article.Title
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

<div class="row">
    <!-- 主内容区：多频道模块网格（仿新浪门户） -->
    <div class="col-lg-8">
        <div class="portal-section-grid">
            @foreach (var channelSection in Model.ChannelSections)
            {
                <section class="portal-block fade-in">
                    <header class="portal-block-header">
                        <h2 class="portal-block-title">
                            <a href="/@channelSection.ChannelSlug">@channelSection.ChannelName</a>
                        </h2>
                        <div class="portal-block-links">
                            <a href="/@channelSection.ChannelSlug" class="more-link text-muted">更多 &gt;</a>
                        </div>
                    </header>

                    <div class="portal-block-body">
                        @if (channelSection.Articles.Any())
                        {
                            var first = channelSection.Articles.First();
                            var rest = channelSection.Articles.Skip(1).Take(6).ToList();

                            <div class="portal-block-main">
                                <article class="portal-main-article">
                                    @if (!string.IsNullOrEmpty(first.CoverImage))
                                    {
                                        <a class="portal-main-thumb"
                                           href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html",
                                                first.ChannelSlug,
                                                first.PublishTime.Year,
                                                first.PublishTime.Month,
                                                first.PublishTime.Day,
                                                first.Id))">
                                            <img src="@first.CoverImage" alt="@first.Title" />
                                        </a>
                                    }
                                    <div class="portal-main-content">
                                        <h3 class="portal-main-title">
                                            <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html",
                                                    first.ChannelSlug,
                                                    first.PublishTime.Year,
                                                    first.PublishTime.Month,
                                                    first.PublishTime.Day,
                                                    first.Id))">
                                                @first.Title
                                            </a>
                                        </h3>
                                        <p class="portal-main-summary">@first.Summary</p>
                                    </div>
                                </article>
                            </div>

                            <ul class="portal-block-list">
                                @foreach (var a in rest)
                                {
                                    <li>
                                        <a href="@(string.Format("/{0}/{1}/{2}/{3}/{4}.html",
                                                    a.ChannelSlug,
                                                    a.PublishTime.Year,
                                                    a.PublishTime.Month,
                                                    a.PublishTime.Day,
                                                    a.Id))">
                                            @a.Title
                                        </a>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </section>
            }
        </div>
    </div>

    <!-- 侧边栏：热门 / 推荐 / 标签云 -->
    <div class="col-lg-4">
        <div class="sidebar">
            @await Component.InvokeAsync("HotArticles")
        </div>
        
        <div class="sidebar">
            @await Component.InvokeAsync("Recommend", new { position = "sidebar", count = 5 })
        </div>
        
        <div class="sidebar">
            @await Component.InvokeAsync("TagCloud")
        </div>
    </div>
</div>