<header class="header-main">
    <div class="container-xl">
        <div class="header-content">
            <div class="header-left">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                    <div class="logo">
                        <span class="logo-text">@ViewBag.WebsiteName</span>
                    </div>
                </a>
            </div>
            <div class="header-center">
                <form asp-controller="Search" asp-action="Index" class="search-form">
                    <div class="search-input-wrapper">
                        <input type="text" name="keyword" placeholder="搜索新闻、资讯、话题" class="search-input" />
                        <button type="submit" class="search-button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <div class="header-right">
                <div class="header-actions">
                    <a href="#" class="header-action-link" title="消息">
                        <i class="bi bi-bell"></i>
                    </a>
                    <a href="#" class="header-action-link" title="收藏">
                        <i class="bi bi-star"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</header>