<div class="footer">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <h4>关于我们</h4>
                <p>@ViewBag.FooterInfo</p>
                <div class="social-links">
                    <a href="#" title="微信"><i class="bi bi-wechat"></i></a>
                    <a href="#" title="微博"><i class="bi bi-weibo"></i></a>
                    <a href="#" title="Twitter"><i class="bi bi-twitter"></i></a>
                    <a href="#" title="GitHub"><i class="bi bi-github"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <h4>快速链接</h4>
                <ul class="list-unstyled">
                    <li><a href="/">首页</a></li>
                    <li><a href="/about">关于我们</a></li>
                    <li><a href="/contact">联系我们</a></li>
                    <li><a href="/privacy">隐私政策</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h4>订阅更新</h4>
                <p>订阅我们的新闻简报，获取最新资讯</p>
                <form class="mt-2">
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="您的邮箱地址" />
                        <button type="submit" class="btn btn-secondary">订阅</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="footer-bottom text-center">
            <p>© @DateTime.Now.Year @ViewBag.WebsiteName. All rights reserved.</p>
        </div>
    </div>
</div>