<div class="footer">
    <div class="container">
        <div class="footer-content">
            <div class="footer-section">
                <h4>关于我们</h4>
                <p>@ViewBag.FooterInfo</p>
                <div class="social-links">
                    <a href="#" title="微信"><i class="bi bi-wechat"></i></a>
                    <a href="#" title="微博"><i class="bi bi-weibo"></i></a>
                    <a href="#" title="Twitter"><i class="bi bi-twitter"></i></a>
                    <a href="#" title="GitHub"><i class="bi bi-github"></i></a>
                </div>
            </div>
            <div class="footer-section">
                <h4>快速链接</h4>
                <ul>
                    <li><a href="/">首页</a></li>
                    <li><a href="/about">关于我们</a></li>
                    <li><a href="/contact">联系我们</a></li>
                    <li><a href="/privacy">隐私政策</a></li>
                    <li><a href="/terms">使用条款</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>热门频道</h4>
                <ul>
                    <li><a href="/news">新闻</a></li>
                    <li><a href="/tech">科技</a></li>
                    <li><a href="/finance">财经</a></li>
                    <li><a href="/sports">体育</a></li>
                    <li><a href="/ent">娱乐</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>订阅更新</h4>
                <p>订阅我们的新闻简报，获取最新资讯</p>
                <div class="footer-subscribe">
                    <form>
                        <input type="email" placeholder="您的邮箱地址" />
                        <button type="submit">订阅</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="footer-bottom-links">
                <a href="/about">关于我们</a>
                <a href="/contact">联系我们</a>
                <a href="/privacy">隐私政策</a>
                <a href="/terms">使用条款</a>
                <a href="/sitemap">网站地图</a>
            </div>
            <p>© @DateTime.Now.Year @ViewBag.WebsiteName. All rights reserved.</p>
        </div>
    </div>
</div>